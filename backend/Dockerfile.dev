# 開発用Dockerfile
FROM golang:1.26-alpine

WORKDIR /app

# 開発ツールのインストール
RUN go install github.com/air-verse/air@latest

# 依存関係ファイルをコピー
# go.sumはgo mod downloadで自動生成されるため、go.modのみコピー
COPY go.mod ./

# 依存関係のダウンロード（go.sumが自動生成される）
RUN go mod download

# Air設定ファイルをコピー
COPY .air.toml .

# ポート公開
EXPOSE 8080

# Airによるホットリロード
CMD ["air", "-c", ".air.toml"]
